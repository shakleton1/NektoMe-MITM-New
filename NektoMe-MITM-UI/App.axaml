<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NektoMe_MITM_UI.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <FluentTheme />
        <Style Selector="Window">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0E1428" Offset="0" />
                    <GradientStop Color="#16223D" Offset="0.45" />
                    <GradientStop Color="#0C1D33" Offset="1" />
                </LinearGradientBrush>
            </Setter>
        </Style>
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F6F8FF" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#AAB7D8" />
        </Style>
        <Style Selector="Border.card">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="#1A2544" />
            <Setter Property="BorderBrush" Value="#2C3C66" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#2B70F2" />
            <Setter Property="Foreground" Value="#F7FAFF" />
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
    </Application.Styles>
</Application>